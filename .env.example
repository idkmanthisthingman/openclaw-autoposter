# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw Autoposter — GitHub Secrets Reference
# ─────────────────────────────────────────────────────────────────────────────
# This file is a REFERENCE ONLY. Never put real values here.
# Add each value as a GitHub secret using:
#   gh secret set SECRET_NAME --body "value"
# Or via GitHub UI: Settings → Secrets and variables → Actions → New repository secret
# ─────────────────────────────────────────────────────────────────────────────

# ── AI / Generation ───────────────────────────────────────────────────────────

# Groq API key — for LLM tweet generation (llama-3.3-70b-versatile)
# Get it at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── X / Twitter Login ─────────────────────────────────────────────────────────

# Your X/Twitter @username (without the @)
X_USERNAME=your_twitter_username

# Your X/Twitter account password
X_PASSWORD=your_twitter_password

# Email address linked to your X/Twitter account
# (used to pass email verification challenges during login)
X_EMAIL=your_email@example.com

# ── Images ────────────────────────────────────────────────────────────────────

# Unsplash Access Key — for high-quality photo search
# Get it at: https://unsplash.com/oauth/applications → New Application
# Note: Only the Access Key is needed here. Keep your Secret Key private and unused.
# Free tier: 50 requests/hour (enough for normal use)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── Optional / Cookies ────────────────────────────────────────────────────────

# X_COOKIES — pre-saved session cookies (optional)
# The bot manages cookies automatically via artifacts.
# Only set this manually if you want to provide a pre-authenticated session.
# X_COOKIES={"ct0":"...","auth_token":"..."}
